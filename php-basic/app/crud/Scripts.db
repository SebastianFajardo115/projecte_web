CREATE DATABASE Dev_BiblioJuegos;

USE Dev_BiblioJuegos;

CREATE TABLE Videojuego (
    id INT PRIMARY KEY NOT NULL AUTO_INCREMENT,
    nombre VARCHAR(100),
    categoria VARCHAR(100),
    precio DOUBLE,
    multijugador BOOLEAN,
    peso DOUBLE
);

